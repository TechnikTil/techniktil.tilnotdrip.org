{
  "name": "backend",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "pnpm exec tsx .",
    "build": "node esbuild.config.js",
    "db:init": "cd database && pnpm exec prisma migrate dev --name init",
    "db:generate": "cd database && pnpm exec prisma generate",
    "db:reset": "cd database && pnpm exec rimraf database/migrations && pnpm exec prisma migrate reset && pnpm run init"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns-tz": "^3.2.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "js-yaml": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/svgdom": "^0.1.2",
    "esbuild": "^0.28.0",
    "esbuild-plugin-copy": "^2.1.1",
    "prisma": "^7.6.0",
    "tsx": "^4.22.4"
  }
}
