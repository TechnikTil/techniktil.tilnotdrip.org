{
	"name": "techniktil.tilnotdrip.org",
	"displayName": "TechnikWebsite",
	"private": true,
	"workspaces": [
		"apps/frontend",
		"apps/backend"
	],
	"scripts": {
		"dev": "concurrently \"bun run --cwd apps/frontend dev\" \"bun run --cwd apps/backend dev\"",
		"clean": "rimraf dist",
		"build": "bun clean && bun --filter=\"*\" run build"
	},
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@types/node": "^25.3.3",
		"concurrently": "^9.2.1",
		"eslint": "^9.36.0",
		"globals": "^16.4.0",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.44.0"
	}
}
